{
  "name": "duck-grades",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:data": "bun scripts/build-data.ts",
    "copy:data:dist": "bun scripts/copy-current-data-to-dist.ts",
    "analyze:budgets": "bun scripts/analyze-budgets.ts",
    "build": "tsc -b && vite build",
    "build:all": "bun run build:data && bun run build && bun run copy:data:dist",
