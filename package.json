{
  "name": "duck-grades",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:catalog": "bun scripts/scrape-uo-catalog.ts",
    "build:programs": "bun scripts/scrape-uo-programs.ts",
    "build:data": "bun scripts/build-data.ts",
    "build:sitemap": "bun scripts/generate-sitemap.ts",
    "copy:public:dist": "bun scripts/copy-public-static-to-dist.ts",
    "copy:data:dist": "bun scripts/copy-current-data-to-dist.ts",
    "analyze:budgets": "bun scripts/analyze-budgets.ts",
    "build": "tsc -b && vite build",
    "build:all": "bun run build:data && bun run build:sitemap && bun run build && bun run copy:public:dist && bun run copy:data:dist",
    "preview": "vite preview",
    "check": "tsc -b --pretty false",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --check \"**/*.{ts,tsx,json,md,js,css}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,json,md,js,css}\""
  },
  "dependencies": {
    "fuzzysort": "^3.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.6",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "csv-parse": "^6.1.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5"
  }
}
